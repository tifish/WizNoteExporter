<Window x:Class="WizNoteExporter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="为知笔记导出"
        FontFamily="Microsoft YaHei UI"
        SizeToContent="Height"
        Width="360"
        MinWidth="320"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="16,12,16,16">
        <TextBlock Margin="0,4,0,6" FontWeight="SemiBold">选择账号</TextBlock>
        <ListBox Name="accountListBox"
                 ItemsSource="{Binding Accounts, Mode=TwoWay}"
                 MaxHeight="180" />

        <TextBlock Margin="0,16,0,6" FontWeight="SemiBold">输出目录</TextBlock>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Name="outputDirTextBox"
                     VerticalContentAlignment="Center"
                     Padding="8,4"
                     Text="我的笔记" />
            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    Padding="14,4"
                    Click="SelectOutputDirButton_Click"
                    Content="选择" />
        </Grid>

        <CheckBox Name="clearOutputDirCheckBox" Margin="0,16,0,0">导出前清空目标文件夹</CheckBox>

        <Button Margin="0,20,0,4"
                Padding="0,8"
                HorizontalAlignment="Stretch"
                FontWeight="SemiBold"
                Click="ExportButton_Click"
                Content="导出所有笔记" />
    </StackPanel>
</Window>
